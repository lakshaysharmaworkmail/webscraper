import { Router, Response } from 'express';
import { authMiddleware, AuthRequest } from '../middleware/auth.js';
const router = Router();

router.post('/scrape', authMiddleware, async (req: AuthRequest, res: Response): Promise<void> => {
  try {
    const { platform, url } = req.body;
    if (!platform || !url) { res.status(400).json({ error: 'Platform and URL are required' }); return; }
    const userId = req.user?.userId || 'unknown';
    const data = await scrapePlatform(platform, url, userId);
    const singleHeaders = { tiktok: ['Video URL', 'Views', 'Likes', 'Comments', 'Shares', 'Duration', 'Upload Date', 'Author Username', 'Display Name', 'Profile URL', 'Followers'] };
    res.json({ headers: singleHeaders[platform] || [], data: [data] });
  } catch (error) { res.status(500).json({ error: error instanceof Error ? error.message : 'Scraping failed' }); }
});

router.post('/scrape/bulk', authMiddleware, async (req: AuthRequest, res: Response): Promise<void> => {
  try {
    const { platform, urls } = req.body;
    const userId = req.user?.userId || 'unknown';
    if (!platform || !urls || !Array.isArray(urls)) { res.status(400).json({ error: 'Platform and URLs array are required' }); return; }
    const results = await Promise.all(urls.map(async (url: string) => {
      try { return await scrapePlatform(platform, url, userId); } catch (e) { return { url, error: 'Failed' }; }
    }));
    const headers = ['Video URL', 'Views', 'Likes', 'Comments', 'Shares', 'Duration', 'Upload Date', 'Author Username', 'Display Name', 'Profile URL', 'Followers'];
    res.json({ headers, data: results });
  } catch (error) { res.status(500).json({ error: error instanceof Error ? error.message : 'Bulk scraping failed' }); }
});

async function scrapePlatform(platform: string, url: string, userId: string) {
  switch (platform) {
    case 'tiktok': return await tiktokScraper(url);
    default: return { url, error: `Platform ${platform} is not supported` };
  }
}

function parseTikTokUrl(url: string): string {
  const match = url.match(/tiktok\.com\/(@[\w.]+|v)\/(\d+)/);
  if (match) return match[0];
  const vm = url.match(/vm\.tiktok\.com\/([\w-]+)/);
  if (vm) return vm[0];
  return url.includes('tiktok') ? url : '';
}

function formatTikTokDuration(seconds: number): string {
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  const s = seconds % 60;
  return [h, m, s].map(x => String(x).padStart(2, '0')).join(':');
}

function formatTikTokDate(timestamp: number, url: string): string {
  try {
    const ts = timestamp > 1e11 ? timestamp : timestamp * 1000;
    const d = new Date(ts);
    console.log(`[TikTok Date Debug] URL: ${url} | Raw: ${timestamp} | Used: ${timestamp > 1e11 ? 'ms' : 'sec'} | Parsed: ${d.toISOString()}`);
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
  } catch { return '-'; }
}

function formatNumberWithCommas(number: number): string {
  if (!number && number !== 0) return '';
  return Number(number).toLocaleString('en-US');
}

async function fetchFollowersSingle(username: string) {
  if (!username) return 'N/A';
  const u = username.replace('@', '').trim();
  try {
    const res = await fetch(`https://www. tikwm. com/api/user/info?unique_id=${encodeURIComponent(u)}`, { method: 'GET', headers: { 'User-Agent': 'Mozilla/5.0', 'Accept': 'application/json' } });
    if (res.status !== 200) return 'N/A';
    const json = await res.json();
    const d = json?.data;
    if (!d) return 'N/A';
    const count = d?.stats?.followerCount || d?.userInfo?.stats?.followerCount || d?.user_info?.stats?.followerCount || d?.followerCount || d?.follower_ count || d?.fans || d?.author?.follower_ count || d?.author_stats?.follower_ count || d?.statistics?.followerCount || 0;
    return count > 0 ? formatNumberWithCommas(count) : 'N/A';
  } catch { return 'N/A'; }
}

async function tiktokScraper(url: string) {
  const videoUrl = parseTikTokUrl(url);
  if (!videoUrl) return { url, error: 'Invalid TikTok URL' };
  try {
    const res = await fetch(`https://www.tikwm. com/api/?url=${encodeURIComponent(videoUrl)}`, { method: 'GET', headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36', 'Accept': 'application/json' } });
    if (res.status !== 200) { const text = await res.text(); console.log('TikTok API error:', res.status, text.substring(0, 200)); return { url, error: 'TikTok API error: ' + res.status }; }
    const json = await res.json();
    if (json && json.data && json.data.title) {
      const d = json.data;
      const username = d.author?.unique_ id || d.author?.uniqueId || '';
      const displayName = d.author?.nickname || username;
      const profileURL = username ? `https://www.tiktok. com/@${username}` : '';
      const subscribers = await fetchFollowersSingle(username);
      return {
        url: videoUrl,
        views: formatNumberWithCommas(d.play_ count || d.statistics?.play_ count || 0),
        likes: formatNumberWithCommas(d.digg_ count || d.statistics?.digg_ count || 0),
        comments: formatNumberWithCommas(d.comment_ count || d.statistics?.comment_ count || 0),
        shares: formatNumberWithCommas(d.share_ count || d.statistics?.share_ count || 0),
        duration: formatTikTokDuration(d.duration || 0),
        uploadDate: formatTikTokDate(d.create_ time || 0, url),
        authorUsername: username ? '@' + username : '',
        displayName: displayName,
        profileUrl: profileURL,
        followers: subscribers
      };
    }
    return { url, error: 'No data in TikTok response' };
  } catch (err) { return { url, error: 'Failed: ' + (err instanceof Error ? err.message : String(err)) }; }
}

export default router;